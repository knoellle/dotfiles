// -*- mode: json -*-

{
  "layer": "top",
  "position": "top",

  "modules-left": [
    "hyprland/workspaces",
    "custom/right-arrow-dark"
  ],
  "modules-center": [
  ],
  "modules-right": [
    "custom/left-arrow-dark",
    "wireplumber",
    "custom/left-arrow-light",
    "network",
    "custom/left-arrow-dark",
    "battery",
    "custom/left-arrow-light",
    "cpu",
    "custom/spacing",
    "temperature",
    "custom/left-arrow-dark",
    "memory",
    "custom/left-arrow-light",
    "disk",
    "custom/left-arrow-dark",
    "clock",
    "tray"
  ],

  "custom/spacing": {
    "format": " ",
    "tooltip": false
  },
  "custom/left-arrow-dark": {
    "format": "о‚І",
    "tooltip": false
  },
  "custom/left-arrow-light": {
