      "п‰Ѓ",
      "п‰Ђ"
    ]
  },
  "disk": {
    "interval": 5,
    "format": "{percentage_used:2}%",
    "path": "/"
  },
  "tray": {
    "icon-size": 20
  },
   "temperature": {
    "interval": 1,
