  "hyprland/workspaces": {
    "format": "{name}",
  },

  "clock": {
    "interval": 1,
    "format": "{:%a %m-%d %T}",
    "tooltip": false
  },

  "wireplumber": {
    "format": "{icon} {volume:2}%",
    "format-bluetooth": "{icon}  {volume}%пЉ”",
    "format-muted": "MUTE",
    "format-icons": {
      "headphones": "пЂҐ",
