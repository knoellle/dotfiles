    "on-click-right": "pavucontrol"
  },
  "memory": {
    "interval": 1,
    "format": "Mem {}%"
  },
  "network": {
    "interval": 1,
    "format-wifi": "{essid} {bandwidthUpBytes} {bandwidthDownBytes} п‡«",
    "format-ethernet": "{bandwidthUpBytes} {bandwidthDownBytes} пћ–",
